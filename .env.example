# Environment Variables Sample for Digi Gov Portal
# Copy this file to .env and fill in your values

# Backend Configuration
NODE_ENV=production
PORT=5000

# MongoDB Configuration
# For Railway: Use the MongoDB plugin connection string
# For local Docker: mongodb://mongodb:27017/govt-shop-portal
MONGO_URI=mongodb://mongodb:27017/govt-shop-portal

# JWT Configuration
# IMPORTANT: Change this to a strong, unique secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin Seed Configuration (used for initial admin user creation)
# IMPORTANT: Change these values in production!
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@digigov.com
ADMIN_PASSWORD=admin123

# AWS S3 / Cloudflare R2 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_BUCKET_NAME=
S3_ENDPOINT=

# Frontend Configuration
# BACKEND_URL is used by nginx to proxy API requests (runtime)
# For Railway: Use your backend service URL (e.g., https://your-backend.up.railway.app)
# For local Docker: http://backend:5000 (uses internal Docker network)
BACKEND_URL=http://backend:5000

# VITE_API_URL is used at build time if you want direct API calls (optional)
# When using nginx proxy (recommended), leave this empty
VITE_API_URL=
