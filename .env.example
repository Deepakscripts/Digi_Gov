# Environment Variables Sample for Digi Gov Portal
# Copy this file to .env and fill in your values

# Backend Configuration
NODE_ENV=production
PORT=5000

# MongoDB Configuration
# For Railway: Use the MongoDB plugin connection string
# For local Docker: mongodb://mongodb:27017/govt-shop-portal
MONGO_URI=mongodb://mongodb:27017/govt-shop-portal

# JWT Configuration
# IMPORTANT: Change this to a strong, unique secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AWS S3 / Cloudflare R2 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_BUCKET_NAME=
S3_ENDPOINT=

# Frontend Configuration
# The URL where your backend API is hosted
# For Railway: Use your backend service URL (e.g., https://your-backend.up.railway.app)
# For local Docker: http://localhost:5000
VITE_API_URL=http://localhost:5000
