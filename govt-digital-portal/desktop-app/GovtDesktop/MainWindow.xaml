<Window x:Class="GovtDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GovtDesktop.ViewModels"
        mc:Ignorable="d"
        Title="Govt Digital Portal - Desktop" Height="600" Width="900"
        Background="#F8FAFC">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Breadcrumbs -->
            <RowDefinition Height="*"/>    <!-- File Grid -->
            <RowDefinition Height="Auto"/> <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Header: Search and Actions -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search & Filter -->
            <StackPanel Orientation="Horizontal">
                <!-- Area Filter -->
                <ComboBox Width="150" Height="35" Margin="0,0,10,0" 
                          ItemsSource="{Binding Areas}" 
                          SelectedItem="{Binding SelectedArea}"
                          DisplayMemberPath="Name"
                          VerticalContentAlignment="Center" Padding="5"
                          ToolTip="Filter by Area (Root Folder)"/>

                <TextBox Width="300" Height="35" VerticalContentAlignment="Center" Padding="5" 
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding PerformSearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Search" Margin="10,0,0,0" Padding="10,5" Command="{Binding PerformSearchCommand}"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="New Folder (Area)" Padding="10,5" Margin="0,0,10,0" Click="OnCreateFolderClick"/>
                <Button Content="Upload" Padding="10,5" Background="#3B82F6" Foreground="White" Click="OnUploadClick"/>
            </StackPanel>
        </Grid>

        <!-- Breadcrumbs -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Breadcrumbs}" Margin="0,0,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text=" > " Foreground="Gray" Margin="5,0"/>
                        <Button Content="{Binding Name}" Command="{Binding DataContext.NavigateBreadcrumbCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="Blue"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <!-- Home Button if Breadcrumbs empty or explicit -->
        <Button Grid.Row="1" HorizontalAlignment="Left" Content="Home" Command="{Binding GoHomeCommand}" 
                Visibility="{Binding CurrentFolder, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="-50,0,0,0"/>


        <!-- File Grid -->
        <ListBox Grid.Row="2" ItemsSource="{Binding Files}" BorderThickness="0" Background="Transparent" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="100" Height="120">
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                          Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                          CommandParameter="{Binding}"/>
                        </Grid.InputBindings>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Icon Placeholder -->
                        <Viewbox Height="60" Width="60" HorizontalAlignment="Center">
                             <Path Fill="{Binding IsFolder, Converter={StaticResource FolderColorConverter}}" 
                                   Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,4H12L10,2L10,4Z" />
                        </Viewbox>

                        <TextBlock Grid.Row="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" 
                                   HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        
                        <TextBlock Grid.Row="2" Text="{Binding Size}" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                        
                        <!-- Context Menu -->
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open" Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                <MenuItem Header="Delete" Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Gray" HorizontalAlignment="Right" Margin="0,10,0,0"/>

    </Grid>
</Window>
